#!/usr/bin/picolisp /usr/lib/picolisp/lib.l
# 24apr26abu

(unless *Dbg
   (load "@lib/vip.l") )

(stack 1024)

(bye
   (if
      (vip~vi  ## [+<pat> | +[<num>]] <file1>  [+[<num>]] <file2> ..
         (make
            (while (opt)
               (let (S @  L (chop S))
                  (cond
                     ((pre? "+" S)
                        (link
                           (cond
                              ((format S) (cons @ (opt)))
                              ((= "+" S) (cons T (opt)))
                              ((get (intern (cdr L)) '*Dbg 1)
                                 (symbols (cddr @))
                                 (cons (car @) (cadr @)) )
                              (T (cons (cdr L) (opt))) ) ) )
                     ((pre? "-" S) (load S))
                     (T (link S)) ) ) ) ) )
      0
      1 ) )
